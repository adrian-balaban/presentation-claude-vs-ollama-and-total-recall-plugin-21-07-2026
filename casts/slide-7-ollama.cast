[1085.078469, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G-\u001b[5G\u001b[1mOllama is the default embedding provider\u001b[46G\u001b[22m(\u001b[38;2;177;185;249mbge-m3\u001b[54G\u001b[39m@\u001b[56G\u001b[38;2;177;185;249m127.0.0.1:11434/api/embeddings\u001b[39m,\u001b[88G10s\u001b[92Gtimeout\u001b[100G+\u001b[102Gone\u001b[106G200ms-backoff\u001b[120Gretry\u001b[126G—\u001b[128Glines\u001b[134G67-87).\r\u001b[1B \u001b[3G- \u001b[1mNo circuit-breaker on the read path\u001b[22m: per the comment \u001b[59Gt l\u001b[64Ges 175-176, \u001b[38;2;177;185;249mrecall_memory\u001b[39m with \u001b[38;2;177;185;249mhybrid=true\u001b[39m \u001b[3malways\u001b[114G\u001b[23mcalls\u001b[120G\u001b[38;2;177;185;249membed()\u001b[128G\u001b[39mand\u001b[132Gdegrades\u001b[141Gvia\u001b[145Gthe\u001b[149Gnull\u001b[154Gpath\u001b[159G—\u001b[161Git\r\u001b[1B  does \u001b[1mnot\u001b[22m consult \u001b[38;2;177;185;249misVectorAvailable()\u001b[39m. So when Ollama\u001b[56Gis\u001b[59Gup\u001b[62Gbut\u001b[66Ghung\u001b[71G(loading/swapping\u001b[89Ga\u001b[91Gmodel\u001b[97Gin\u001b[100GVRAM),\u001b[107Gevery\u001b[113Ghybrid\u001b[120Gquery\u001b[126Gpays\u001b[131Gup\u001b[134Gto\u001b[137G\u001b[1m~20s\u001b[142G\u001b[22m(2×\u001b[146Gthe\u001b[150G10s\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249mAbortController\u001b[19G\u001b[39mtimeout)\u001b[28Gbefore\u001b[35Gfalling\u001b[43Gback\u001b[48Gto\u001b[51GTF-IDF.\u001b[59GThe\u001b[63Glive\u001b[68G\u001b[38;2;177;185;249mget_stats\u001b[78G\u001b[39merrors\u001b[85G(\"This\u001b[92Goperation\u001b[102Gwas\u001b[106Gaborted\")\u001b[116Gare\u001b[120Gexactly\u001b[128Gthis\u001b[133G\u001b[38;2;177;185;249mAbortController\u001b[149G\u001b[39mfiring\u001b[156G—\u001b[158GOllama\r\u001b[2C\u001b[1Bis reachable but\u001b[20Ghanging.\r\u001b[2C\u001b[1B-\u001b[5GFailure\u001b[13G\u001b[1mis\u001b[16G\u001b[22mobservable\u001b[27G(\u001b[38;2;177;185;249mrecordError\u001b[40G\u001b[39m→\u001b[42G\u001b[38;2;177;185;249mget_stats.