[19.49347, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[25B\u001b[38;2;177;185;249m/model                                                      Set the AI model for Claude Code (currently glm-5.2:cloud)\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153m/claude-api                                                 Reference for the Claude API / Anthropic SDK — \u001b[38;2;177;185;249mmod\u001b[38;2;153;153;153mel ids, pricing, params, streaming, tool use, MCP,\r\u001b[2C\u001b[1B\u001b[39m                                                            \u001b[38;2;153;153;153magents,\u001b[72Gaching, token counting, \u001b[38;2;177;185;249mmod\u001b[38;2;153;153;153mel migr\u001b[107Gtion. TRIGGER — read BEFORE opening the target file; do…\r\u001b[3C\u001b[1Bbrainstorming  \u001b[64Gsuperpowers) You MUST u\u001b[88Ge this\u001b[95Gbefore any creative work - creating features, b\u001b[143Gilding component\u001b[160G,\r\u001b[62C\u001b[1Badding func\u001b[75Gionality, or \u001b[38;2;177;185;249mmod\u001b[38;2;153;153;153mifying\u001b[98Gbehavior.\u001b[108GExplores user intent, requirements and design\u001b[154Gb\u001b[156Gfore i\u001b[39m\u001b[35;1H\u001b[32;7H\u001b[?25h\u001b[?2026l"]
