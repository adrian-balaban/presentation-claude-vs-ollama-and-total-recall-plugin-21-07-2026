[1348.761517, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[4C\u001b[38B\u001b[38;2;153;153;153mode-review\u001b[36Gview the current diff for correctness bugs\r\u001b[33C\u001b[1Band r\u001b[40Guse/\u001b[45Gim\u001b[48Gl\u001b[50Gf\u001b[52Gcation/efficiency cleanup\u001b[39m\u001b[45;1H\u001b[42;9H\u001b[?25h\u001b[?2026l"]
[1348.784417, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[4C\u001b[38B\u001b[38;2;153;153;153mlaude-api \u001b[36Gference for the Claude API / Anthropic SDK\r\u001b[33C\u001b[1B— \u001b[38;2;177;185;249mmodel\u001b[38;2;153;153;153m id\u001b[45G, \u001b[48Gr\u001b[50Gc\u001b[52Gng, params, streaming, to\u001b[39m\u001b[45;1H\u001b[42;9H\u001b[?25h\u001b[?2026l"]
[1349.075487, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[23B\u001b[38;2;177;185;249m▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔▔\r\u001b[3C\u001b[1B\u001b[1mSelect model\r\u001b[3C\u001b[1B\u001b[22m\u001b[38;2;153;153;153mSwitch between Claude models. Your pick becomes the default for new \r\u001b[3C\u001b[1Bsessions. For other/previous model names, specify with --model.\r\u001b[5C\u001b[2B1. \u001b[39mDefault\u001b[17G(recommended)\u001b[32G\u001b[38;2;153;153;153mSonnet 4.6 · Efficient for routine tasks\r\u001b[5C\u001b[1B2. \u001b[39mSonnet\u001b[32G\u001b[38;2;153;153;153mSonnet 4.6 · Efficient for routine tasks\r\u001b[5C\u001b[1B3. \u001b[39mSonnet\u001b[16G(1M\u001b[20Gcontext)\u001b[32G\u001b[38;2;153;153;153mSonnet 4.6 with 1M context · Draws from usage\r\u001b[31C\u001b[1Bcredits · $3/$15 per Mtok\r\u001b[5C\u001b[1B4. \u001b[39mFable\u001b[32G\u001b[38;2;215;119;87mFable 5\u001b[38;2;153;153;153m · Most capable for your hardest and \r\u001b[31C\u001b[1Blongest-running tasks · Uses your limits ~2× \r\u001b[31C\u001b[1Bfaster than Opus\r\u001b[5C\u001b[1B5. \u001b[39mOpus\u001b[32G\u001b[38;2;153;153;153mOpus 4.8 · Best for everyday, complex tasks ·\r\u001b[2C\u001b[1B\u001b[39m                             \u001b[38;2;153;153;153m~2× usage vs Sonnet\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;2;153;153;153m6. \u001b[39mHaiku\u001b[32G\u001b[38;2;153;153;153mHaiku 4.5 · Fastest for quick answers\r\u001b[2C\u001b[1B\u001b[39m \u001b[38;2;177;185;249m❯\u001b[39m \u001b[38;2;153;153;153m7. \u001b[38;2;78;186;101mglm-5.2:cloud\u001b[39m \u001b[38;2;78;186;101m✔\u001b[39m        \u001b[38;2;153;153;153mCustom mod\u001b[43Gl\u001b[39m\u001b[K\r\u001b[33C\u001b[1B\u001b[K\r\u001b[1B   \u001b[38;2;215;119;87m●\u001b[38;2;153;153;153m High effort (default) \u001b[38;2;80;80;80m←/→ to adjust\u001b[39m\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B   \u001b[38;2;153;153;153mUse \u001b[1m/fast\u001b[22m to turn on Fast mode (Opus 4.8).\u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[3C\u001b[1B\u001b[38;2;153;153;153mEnter to set as default · s to use this session only · Esc to cancel\u001b[39m\u001b[45;1H\u001b[39;4H\u001b[?2026l"]
[1349.195428, "o", "\u001b[?2026h\u001b[H\r\u001b[3C\u001b[5B\u001b[38;2;255;193;7m10 setup i\u001b[15Gsues: MCP\u001b[38;2;153;153;153m · /doctor\u001b[39m\u001b[45;1H\u001b[39;4H\u001b[?2026l"]
