1b[76G\u001b[38;2;177;185;249mrecall_memory\u001b[90G\u001b[39mwith\u001b[95G\u001b[38;2;177;185;249mhybrid=true\u001b[107G\u001b[39m\u001b[3malways\u001b[114G\u001b[23mcalls\u001b[120G\u001b[38;2;177;185;249membed()\u001b[128G\u001b[39mand\u001b[132Gdegrades\u001b[141Gvia\u001b[145Gthe\u001b[149Gnull\u001b[154Gpath\u001b[159G—\u001b[161Git\r\u001b[2C\u001b[1Bdoes \u001b[1mnot\u001b[22m consult \u001b[38;2;177;185;249misVectorAvailable()\u001b[39m. So when Ollama\u001b[56Gis up but hung (loading/swapping a model in\u001b[100GVRAM), every hybrid\u001b[120Gque\u001b[126Gpays up\u001b[134Gto \u001b[1m~20s\u001b[142G\u001b[22m(2×\u001b[146Gthe\u001b[150G10s\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249mAbortController\u001b[39m timeout) before falling back to TF-IDF. The live \u001b[38;2;177;185;249mget_stats\u001b[39m errors (\"This operation was aborted\") are\u001b[120Gexactly\u001b[128Gthis \u001b[38;2;177;185;249mAbortController\u001b[149G\u001b[39mfiring — Ollama\r\u001b[2C\u001b[1Bis reachable bu\u001b[20Ghanging.\u001b[K\r\u001b[2C\u001b[1B- Failure \u001b[1mis\u001b[22m observable (\u001b[38;2;177;185;249mrecordError\u001b[39m → \u001b[38;2;177;185;249mget_stats.recentErrors\u001b[39m), but there's no SessionStart b\u001b[97Gnner\u001b[104Grning \u001b[111Ghe use\u001b[118G v\u001b[121Gctor search\u001b[133Gis dark — silent degradation\u001b[K\r\u001b[2C\u001b[1Bunless you ask for stats\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BThe workflow's\u001b[18Greviewer\u001b[27G +\u001b[30Gadversarial\u001b[42Gverifiers\u001b[52Gwill\u001b[57Gconfirm\u001b[65Gor\u001b[68Grefute\u001b[75Gthis\u001b[80Gagainst\u001b[88Gthe\u001b[92Gcode.\u001b[98GWaiting\u001b[106Gfor\u001b[110Git\u001b[113Gto\u001b[116Gcomplete\u001b[125Gbefore\u001b[132Gauthoring\u001b[142Gthe\u001b[146Gfile.\r\u001b[2B\u001b[38;2;78;186;101m●\u001b[3G\u001b[39m\u001b[1mTask Output\u001b[22m\u001b[38;2;153;153;153m wqrui8qin\u001b[39m\u001b[K\r\u001b[1B  GLM-5.2\u001b[11Greview\u001b[18Gof\u001b[21Gth