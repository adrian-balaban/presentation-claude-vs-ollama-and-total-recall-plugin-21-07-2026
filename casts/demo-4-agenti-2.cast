[109.212898, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[35B\u001b[38;2;177;185;249m/status                                                     Show Claude Code status including version, model, account, API connectivity, and tool statuses\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153m/\u001b[5G\u001b[38;2;177;185;249mt\u001b[38;2;153;153;153mickers                                                   Order Claude Code \u001b[38;2;177;185;249mst\u001b[38;2;153;153;153mickers\u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;153;153;153m/\u001b[38;2;177;185;249mst\u001b[38;2;153;153;153matusline                                                 Set up Claude Code's \u001b[38;2;177;185;249mst\u001b[38;2;153;153;153matus line UI\u001b[39m\u001b[K\r\u001b[4C\u001b[1B\u001b[38;2;177;185;249mt\u001b[38;2;153;153;153mrands-agent\u001b[65Gws-\u001b[69Gev-toolkit) Scaffold and build AI a\u001b[107Gts using th\u001b[119G \u001b[38;2;177;185;249mSt\u001b[38;2;153;153;153mrands Agents SDK\u001b[139Gw\u001b[141Gth Bedrock AgentCore. Use when creating new\u001b[39m\u001b[K\r\u001b[62C\u001b[1B\u001b[38;2;153;153;153magent projects, building gree\u001b[93Gfield\u001b[99GAge\u001b[103GtC\u001b[106Gr\u001b[109Gapplications, prototyping agen\u001b[140Gs with\u001b[147G\u001b[38;2;177;185;249mSt\u001b[38;2;153;153;153mrands, or when asked about\u001b[176Gthe Strands \u001b[39m\u001b[45;1H\u001b[42;6H\u001b[?25h\u001b[?2026l"]
