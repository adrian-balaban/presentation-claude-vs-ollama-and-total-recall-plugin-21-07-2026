[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m\u001b[4G \u001b[3G⚠️\u001b[5G Problemă: vector search OFF din nou\r\u001b[2C\u001b[1B\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;2;177;185;249mvectorSearchEnabled: false\u001b[30G\u001b[39m—\u001b[32GOllama\u001b[39Gembedding\u001b[49Ga\u001b[51Geșuat\u001b[57Gla\u001b[60G\u001b[1m15:33\u001b[66G\u001b[22m(10\u001b[70Gerori\u001b[76G\"This\u001b[82Goperation\u001b[92Gwas\u001b[96Gaborted\").\u001b[107GAsta\u001b[112Gînseamnă\u001b[121Gcă\u001b[124Grecall-ul\u001b[134Ghibrid\u001b[141G(TF-IDF\u001b[149G+\u001b[151GRRF\u001b[155Gvia\u001b[159G\u001b[38;2;177;185;249mbge-m3\u001b[39m)\u001b[167Ge\u001b[169Gcăzut\u001b[175Gînapoi\u001b[182Gpe\u001b[185GTF-IDF\r\u001b[2C\u001b[1Bdoar.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BRecall-ul\u001b[13Gfuncționează,\u001b[27Gdar\u001b[31Gfără\u001b[36Gcomponenta\u001b[47Gsemantică.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BRepo:\u001b[9G562\u001b[13Ge\u001b[15Gconsistent\u001b[26Gcu\u001b[29Gindex-ul\u001b[38Grebuild-uit\u001b[50Ganterior\u001b[59G(772\u001b[64G→\u001b[66G562\u001b[70Gdupă\u001b[75Gștergerea\u001b[85Gcelor\u001b[91G210\u001b[95Gfișiere\u001b[103G\u001b[38;2;177;185;249marchitecture/\u001b[117G\u001b[39mdin\u001b[121Gorg\u001b[125Gvault).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BVrei\u001b[8Gsă\u001b[11Grepornesc\u001b[21GOllama\u001b[28G/\u001b[30Grebuild\u001b[38Gnative\u001b[45Gdeps\u001b[50Gpentru\u001b[57Ga\u001b[59Greactiva\u001b[68Gvector\u001b[75Gsearch?\u001b[83G(am\u001b[87Gmai\u001b[91Gfăcut-o\u001b[99Gazi\u001b[103Gla\u001b[106G18:09\u001b[112Gși\u001b[115G18:29\u001b[121G—\u001b[123Ga\u001b[125Gpicat\u001b[131Gdin\u001b[135Gnou\u001b[139Gla\u001b[142G15:33).\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m✻\u001b[3GCooked for 25s\r\u001b[1B\u001b[39m\u001b[K\r\u001b[1"]
