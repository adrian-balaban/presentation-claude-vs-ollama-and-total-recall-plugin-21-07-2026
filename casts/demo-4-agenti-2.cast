[142.511331, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[38;2;177;185;249m──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\r\u001b[1C\u001b[1B\u001b[1mBash command\r\u001b[1C\u001b[1B\u001b[22m\u001b[39m\u001b[K\r\u001b[3C\u001b[1Bcat\u001b[8G>\u001b[10G/tmp/recall_stats.js\u001b[31G<<\u001b[34G'EOF'\r\u001b[1C\u001b[1B \u001b[4Gconst { execSync } = require('child_proc\u001b[45Gss');\u001b[K\r\u001b[1C\u001b[1B\u001b[K\r\u001b[1B   try {                                                                                                           \u001b[48;2;38;79;120m                       \u001b[49m\u001b[K\r\u001b[5C\u001b[1B//\u001b[9GTry\u001b[13Gto\u001b[16Ginvoke\u001b[23Gtotal-recall\u001b[36Gget_stats\u001b[46Gvia\u001b[50GMCP\r\u001b[1B     const result = execSync('total-recall get_stats', { encoding: 'utf-8' });\u001b[K\r\u001b[1B     console.\u001b[15Gog(result);\u001b[K\r\u001b[3C\u001b[1B}\u001b[6Gcatch\u001b[12G(e)\u001b[16G{\r\u001b[1B     console.error('Error:', e.message);\u001b[K\r\u001b[1B     // Fallback: coun\u001b[24G files in vault\u001b[40G\u001b[K\r\u001b[5C\u001b[1Bconst\u001b[12Gfs\u001b[15G=\u001b[17Grequire('fs');\r\u001b[1B     const path = '/home/adrianb/.total-recall/personal-vault';\u001b[K\r\u001b[5C\u001b[1Bconst\u001b[12Gcategories\u001b[23G=\u001b[25Gfs.readdirSync(path).filter(f\u001b[55G=>\u001b[58G!f.startsWith('.'));\r\u001b[1B\u001b[K\r\u001b[5C\u001b[1Blet\u001b[10Gtotal\u001b[16G=\u001b[18G0;\r\u001b[2C\u001b[1B   const counts = {};\r\u001b[2B \u001b[3G   categories.forE\u001b[22Gch(cat => {\u001b[K\r\u001b[7C\u001b[1Bif\u001b[11G(fs.statSync(path\u001b[29G+\u001b[31G'/'\u001b[35G+\u001b[37Gcat).isDirectory())\u001b[57G{\r\u001b[2C\u001b[1B       const files =\u001b[24Gfs.readdirSync(path\u001b[44G+\u001b[46G'/'\u001b[50G+\u001b[52Gcat).length;\r\u001b[9C\u001b[1Bcounts[cat]\u001b[22G=\u001b[24Gfiles;\r\u001b[1B \u001b[3G   \u001b[7G   total += files;\u001b[K\r\u001b[7C\u001b[1B}\r\u001b[1B \u001b[3G   });\u001b[K\r\u001b[1B\u001b[K\r\u001b[5C\u001b[1Bconsole.log(`\\n📊 Memory Stats (file-based fallback)\\n`);\r\u001b[5C\u001b[1Bconsole.log(`Total\u001b[25Gmemories:\u001b[35G${total}\\n`);\r\u001b[5C\u001b[1BObject.entries(counts).sort((a,b) => b[1] - a[1]).forEach(([cat,\u001b[71Gcount])\u001b[79G=>\u001b[82G{\r\u001b[5C\u001b[1B  console.log(`  ${cat}: ${count}`);\u001b[K\r\u001b[5C\u001b[1B});\u001b[K\r\u001b[3C\u001b[1B}\u001b[6G\u001b[K\r\u001b[3C\u001b[1BEOF\u001b[K\r\u001b[3C\u001b[1Bnode /tmp/recall_stats.js\r\u001b[3C\u001b[1B\u001b[38;2;153;153;153mRun shell command\r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B Contains brace with quote character (expansion obfuscation)\r\u001b[80C\u001b[1B\u001b[K\r\u001b[1B Do you want to proceed?\u001b[K\r\u001b[1B \u001b[38;2;177;185;249m❯\u001b[4G\u001b[38;2;153;153;153m1. \u001b[38;2;177;185;249mYes\r\u001b[1B\u001b[39m   \u001b[38;2;153;153;153m2. \u001b[39mNo\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1C\u001b[1B\u001b[38;2;153;153;153mEsc to cancel · Tab to amend · ctrl+e to explain\u001b[39m\u001b[45;1H\u001b[42;2H\u001b[?2026l"]
