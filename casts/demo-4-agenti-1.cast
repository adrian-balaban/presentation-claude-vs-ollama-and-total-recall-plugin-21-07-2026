const counts = {};\r\u001b[2B \u001b[3G   categories.forE\u001b[22Gch(cat => {\u001b[K\r\u001b[7C\u001b[1Bif\u001b[11G(fs.statSync(path\u001b[29G+\u001b[31G'/'\u001b[35G+\u001b[37Gcat).isDirectory())\u001b[57G{\r\u001b[2C\u001b[1B       const files =\u001b[24Gfs.readdirSync(path\u001b[44G+\u001b[46G'/'\u001b[50G+\u001b[52Gcat).length;\r\u001b[9C\u001b[1Bcounts[cat]\u001b[22G=\u001b[24Gfiles;\r\u001b[1B \u001b[3G   \u001b[7G   total += files;\u001b[K\r\u001b[7C\u001b[1B}\r\u001b[1B \u001b[3G   });\u001b[K\r\u001b[1B\u001b[K\r\u001b[5C\u001b[1Bconsole.log(`\\nрҹ“Ҡ Memory Stats (file-based fallback)\\n`);\r\u001b[5C\u001b[1Bconsole.log(`Total\u001b[25Gmemories:\u001b[35G${total}\\n`);\r\u001b[5C\u001b[1BObject.entries(counts).sort((a,b) => b[1] - a[1]).forEach(([cat,\u001b[71Gcount])\u001b[79G=>\u001b[82G{\r\u001b[5C\u001b[1B  console.log(`  ${cat}: ${count}`);\u001b[K\r\u001b[5C\u001b[1B});\u001b[K\r\u001b[3C\u001b[1B}\u001b[6G\u001b[K\r\u001b[3C\u001b[1BEOF\u001b[K\r\u001b[3C\u001b[1Bnode /tmp/recall_stats.js\r\u001b[3C\u001b[1B\u001b[38;2;153;153;153mRun shell command\r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B Contains brace with quote character (expansion obfuscation)\r\u001b[80C\u001b[1B\u001b[K\r\u001b[1B Do you want to proceed?\u001b[K\r\u001b[1B \u001b[38;2;177;185;249mвқҜ\u001b[4G\u001b[38;2;153;153;153m1. \u001b[38;2;177;185;249mYes\r\u001b[1B\u001b[39m   \u001b[38;2;153;153;153m2. \u001b[39mNo\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1C\u001b[1B\u001b[38;2;153;153;153mEsc to cancel В· Tab to amend В· ctrl+e to explain\u001b[39m\u001b[45;1H\u001b[42;2H\u001b[?2026l"]
