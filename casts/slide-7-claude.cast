u001b[113GMatch-ul\u001b[122G#1\u001b[125Ge\r\u001b[2C\u001b[1Btotuși\u001b[10Gclar\u001b[15Gdominant\u001b[24G(70\u001b[28Gvs\u001b[31G16).\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m✻\u001b[39m \u001b[38;2;153;153;153mCrunched for 30s\u001b[39m\u001b[K\r\u001b[3B❯ \r\u001b[2C\u001b[3B\u001b[38;2;153;153;153m← for agents\u001b[39m\u001b[45;1H\u001b[42;3H\u001b[?25h\u001b[?2026l"]
