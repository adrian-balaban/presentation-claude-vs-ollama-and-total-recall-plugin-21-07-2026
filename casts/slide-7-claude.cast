0\u001b[111Gpentru\u001b[118GOllama).\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1m#9\u001b[8G\u001b[22m—\u001b[10Gpreferința\u001b[21Gechipei\u001b[29Gpentru\u001b[36G\u001b[38;2;177;185;249mollama launch claude\u001b[57G\u001b[39mlocal.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BVrei\u001b[8Gsă\u001b[11Gîncerc\u001b[18Grebuild-ul\u001b[29Gde\u001b[32Gnative\u001b[39Gdeps\u001b[44Gca\u001b[47Gsă\u001b[50Grepun\u001b[56Gvector\u001b[63Gsearch\u001b[70Gpe\u001b[73Gpicioare?\u001b[83G(memoria\u001b[92G#6\u001b[95Gare\u001b[99Gpașii\u001b[105Gexacti)\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m✻\u001b[39m \u001b[38;2;153;153;153mCooked for 1m 11s\u001b[39m\u001b[K\r\u001b[3B❯ \r\u001b[2C\u001b[3B\u001b[38;2;153;153;153m← for agents\u001b[39m\u001b[45;1H\u001b[42;3H\u001b[?25h\u001b[?2026l"]
