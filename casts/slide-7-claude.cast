[3543.091085, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[4C\u001b[2B5\u001b[11G3\u001b[13G5\u001b[19GApache Flink 2.3 docs — SQL Reference: Utility Statements \u001b[78G   \u001b[82G     \u001b[88G          \u001b[101G\u001b[1morg\u001b[22m     \r\u001b[4C\u001b[2B6\u001b[11G2\u001b[13G0\u001b[19Gtotal-recall: Copilot\u001b[41GCLI hooks port —\u001b[58Gkey design d\u001b[71Gcisions\u001b[101Gpersonal\r\u001b[4C\u001b[2B7\u001b[19GFlink SQL and\u001b[33GTable API  \u001b[45G     \u001b[51G    \u001b[56G \u001b[58G   \u001b[62G      \u001b[69G         \r\u001b[4C\u001b[2B8\u001b[11G1\u001b[19GData Pipeli\u001b[31Ges & ETL (Flink)\r\u001b[4C\u001b[2B9\u001b[11G0\u001b[13G6\u001b[19GeGPU\u001b[24Gv\u001b[26Ga Thunderbolt\u001b[40G4 — only\u001b[49GGPU-upgrade\u001b[61Gpath\u001b[66Gfor\u001b[70Gsoldered-dGPU\u001b[84Glaptop\r\u001b[2C\u001b[1B└\u001b[9G┴\u001b[17G┴\u001b[99G┴\u001b[110G┘\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mRelevant\u001b[22m\u001b[K\r\u001b[2C\u001b[2B- \u001b[1m#1\u001b[22m (exact\u001b[15Gmatch,\u001b[22Gstocat\u001b[29Gacum\u001b[34Gcâteva\u001b[41Gminute)\u001b[49G—\u001b[51G\u001b[38;2;177;185;249mgemma3:4b\u001b[61G\u001b[39mcold-load\u001b[71G≈\u001b[73G2\u001b[75Gmin\u001b[79Gpe\u001b[82Glaptopul\u001b[91Gde\u001b[94Gdemo,\u001b[100Gwarm\u001b[105GTTFT\u001b[110G~1776ms.\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1m#9\u001b[8G\u001b[22m—\u001b[10Glegat\u001b[16Gtangențial:\u001b[28Gcontext\u001b[36Ghardware\u001b[45Glocal-LLM\u001b[55G(eGPU/TB4,\u001b[66GVRAM,\u001b[72GOllama)\u001b[80Gpentru\u001b[87Gacelași\u001b[95GDell\u001b[100GLatitude.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mIrrelevant (noise TF-IDF)\u001b[22m\u001b[K\r\u001b[2C\u001b[2B- #2, #3, #5, #7, #8 — toate\u001b[32GFlink\u001b[38G\"LOAD\u001b[44Gstatements\",\u001b[57Gprin\u001b[62Gcoincidență\u001b[74Glexicală\u001b[83Gpe\u001b[86G\"load\".\u001b[94GFără\u001b[99Glegătură\u001b[108Gcu\u001b[111Ggemma.\r\u001b[2C\u001b[1B-\u001b[5G#4\u001b[8G—\u001b[10G\"cold-start\"\u001b[23Gîn\u001b[26Gcontext\u001b[34GFlink/k8s,\u001b[45Gnu\u001b[48GOllama.\r\u001b[5C\u001b[1B6 — port Copilot,\u001b[24Gma\u001b[27Gch pe \"load-bearing\".\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNotă: căutarea e TF-IDF (vector search încă down),\u001b[54Gde\u001b[57Gaceea\u001b[63Gapar\u001b[68Gși\u001b[71GFlink\u001b[77G\"LOAD\"\u001b[84Gca\u001b[87Gnoise\u001b[93Gpe\u001b[96Gtoken-ul\u001b[105G\"load\".\u001b[113GMatch-ul\u001b[122G#1\u001b[125Ge\r\u001b[2C\u001b[1Btotuși\u001b[10Gclar\u001b[15Gdominant\u001b[24G(70\u001b[28Gvs\u001b[31G16).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;2;153;153;153m✻\u001b[3GCrunched for 30s\u001b[39m\u001b[K\r\u001b[2B\u001b[48;2;55;55;55m\u001b[38;2;80;80;80m❯ \u001b[38;2;255;255;255mcaută semantic: \"cât durează să pornească un model local mic?\"\u001b[39m                                                                 \r\u001b[2B\u001b[49m  \u001b[38;2;153;153;153mThought for \u001b[1m45s\u001b[22m, called plugin:total-recall:total-recall \u001b[39m\u001b[K\r\u001b[2B\u001b[38;2;255;255;255m●\u001b[3G\u001b[39m\u001b[1mRezultate \"cât durează să pornească un model local mic?\"\u001b[22m\u001b[K\r\u001b[2B \u001b[4G \u001b[3G⚠️\u001b[5G \u001b[1mVector\u001b[13Gsearch încă down\u001b[22m — rezultatele de mai jos sunt\u001b[60Gtot\u001b[64GTF-IDF\u001b[71G(hybrid\u001b[79Ga\u001b[81Gcăzut\u001b[87Ggrațios\u001b[95Gpe\u001b[98Glexical).\u001b[108GConfirmă:\u001b[118Gtop-hit\u001b[126Ge\r\u001b[2C\u001b[1BFlink\u001b[9G\"model\u001b[16Gfunctions\"\u001b[27G(coincidență\u001b[40Gpe\u001b[43G\"model\"),\u001b[53GNU\u001b[56Gmemoria\u001b[64Grelevantă.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B| # |\u001b[9GSc\u001b[12Gr\u001b[14G | Title | Vault |\u001b[K\u001b[45;1H\u001b[42;3H\u001b[?25h\u001b[?2026l"]
